# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real keys.

# --- Database (docker-compose) ---
DB_NAME=townpulse_db
DB_USER=postgres
DB_PASSWORD=postgres

# --- Seattle Socrata (data.seattle.gov) ---
# Optional: unauthenticated requests are throttled. Register at
# https://evergreen.data.socrata.com/signup to get an app token.
SEATTLE_SOCRATA_APP_TOKEN=

# --- Ticketmaster Discovery ---
# Register at https://developer.ticketmaster.com/ to get a key.
TICKETMASTER_API_KEY=
